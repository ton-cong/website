<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.repository.CartItemRepository">

    <resultMap id="CartItemResultMap" type="com.example.demo.entity.CartItem">
        <id property="id" column="id"/>
        <result property="cartId" column="cart_id"/>
        <result property="productVariantId" column="product_variant_id"/>
        <result property="quantity" column="quantity"/>
        <association property="productVariant" javaType="com.example.demo.entity.ProductVariant">
            <id property="id" column="pv_id"/>
            <result property="price" column="pv_price"/>
            <result property="salePrice" column="pv_sale_price"/>
            <result property="stock" column="pv_stock"/>
            <result property="specifications" column="pv_specifications"/>
            <association property="product" javaType="com.example.demo.entity.Product">
                <id property="id" column="p_id"/>
                <result property="name" column="p_name"/>
                <result property="imageUrl" column="p_image_url"/>
            </association>
        </association>
    </resultMap>

    <sql id="selectWithProduct">
        SELECT ci.*, 
               pv.id AS pv_id, pv.price AS pv_price, pv.sale_price AS pv_sale_price, pv.stock AS pv_stock, pv.specifications AS pv_specifications,
               p.id AS p_id, p.name AS p_name, p.image_url AS p_image_url
        FROM cart_items ci
        LEFT JOIN product_variants pv ON ci.product_variant_id = pv.id
        LEFT JOIN products p ON pv.product_id = p.id
    </sql>

    <select id="findById" parameterType="int" resultMap="CartItemResultMap">
        <include refid="selectWithProduct"/>
        WHERE ci.id = #{id}
    </select>

    <select id="findByCartId" parameterType="int" resultMap="CartItemResultMap">
        <include refid="selectWithProduct"/>
        WHERE ci.cart_id = #{cartId}
    </select>

    <insert id="insert" parameterType="com.example.demo.entity.CartItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO cart_items (cart_id, product_variant_id, quantity)
        VALUES (#{cartId}, #{productVariantId}, #{quantity})
    </insert>

    <update id="save" parameterType="com.example.demo.entity.CartItem">
        UPDATE cart_items SET quantity = #{quantity} WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="int">
        DELETE FROM cart_items WHERE id = #{id}
    </delete>

    <delete id="deleteByCartId" parameterType="int">
        DELETE FROM cart_items WHERE cart_id = #{cartId}
    </delete>
    <delete id="deleteByProductVariantId" parameterType="int">
        DELETE FROM cart_items WHERE product_variant_id = #{productVariantId}
    </delete>

</mapper>
